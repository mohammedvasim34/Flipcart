def decode_geo(g):
    try:
        lat, lon = pgh.decode(g)
        return pd.Series([float(lat), float(lon)])
    except:
        return pd.Series([np.nan, np.nan])

train[["lat","lon"]] = train["geohash"].apply(decode_geo)
