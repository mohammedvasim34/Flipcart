    te.fit(
        train.iloc[tr_idx][["geohash"]],
        train.iloc[tr_idx]["demand"]
    )

    train.loc[
        val_idx,
        "geo_te"
    ] = te.transform(
        train.iloc[val_idx][["geohash"]]
    ).values.ravel()

