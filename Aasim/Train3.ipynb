"""
# 8. OOF SUMMARY
# ─────────────────────────────────────────────
print("\n" + "="*55)
print("OOF R2 SCORES (log-space)")
print("="*55)
print(f"  CatBoost  OOF R2: {r2_score(y, oof_cat):.5f}")
print(f"  LightGBM  OOF R2: {r2_score(y, oof_lgb):.5f}")
print(f"  XGBoost   OOF R2: {r2_score(y, oof_xgb):.5f}")


# ─────────────────────────────────────────────
# 9. RIDGE META-LEARNER
# ─────────────────────────────────────────────
print("\nTraining Ridge meta-learner...")
meta_train = np.column_stack([oof_cat, oof_lgb, oof_xgb])
meta_test  = np.column_stack([pred_cat, pred_lgb, pred_xgb])

best_alpha, best_r2 = 1.0, -np.inf
for alpha in [0.001, 0.01, 0.1, 1.0, 10.0, 100.0]:
    oof_ridge = np.zeros(len(y))
    for tr_idx, val_idx in KFold(n_splits=5, shuffle=True, random_state=99).split(meta_train):
        r = Ridge(alpha=alpha)
        r.fit(meta_train[tr_idx], y[tr_idx])
        oof_ridge[val_idx] = r.predict(meta_train[val_idx])
    r2 = r2_score(y, oof_ridge)
    if r2 > best_r2:
        best_r2, best_alpha = r2, alpha

print(f"  Best alpha: {best_alpha}  |  Meta OOF R2 (log): {best_r2:.5f}")

final_ridge = Ridge(alpha=best_alpha)
final_ridge.fit(meta_train, y)
print(f"  Ridge weights → CatBoost:{final_ridge.coef_[0]:.3f}  "
      f"LightGBM:{final_ridge.coef_[1]:.3f}  XGBoost:{final_ridge.coef_[2]:.3f}")

final_pred_log = final_ridge.predict(meta_test)


# ─────────────────────────────────────────────
# 10. INVERSE TRANSFORM + CLIP
# ─────────────────────────────────────────────
final_pred = np.expm1(final_pred_log)
final_pred = np.clip(final_pred, 0.0, 1.0)

# Estimate score in original space using OOF
oof_meta_log = final_ridge.predict(meta_train)
oof_meta     = np.clip(np.expm1(oof_meta_log), 0.0, 1.0)
oof_r2       = r2_score(train_fe['demand'].values, oof_meta)
print(f"\n  OOF R2 (original space): {oof_r2:.5f}")
print(f"  Estimated Score = {max(0, 100 * oof_r2):.2f}")

print(f"\nPrediction stats:")
print(f"  min={final_pred.min():.6f}  max={final_pred.max():.6f}  "
      f"mean={final_pred.mean():.6f}  std={final_pred.std():.6f}")


# ─────────────────────────────────────────────
# 11. SAVE SUBMISSION
# ─────────────────────────────────────────────
submission = pd.DataFrame({
    'Index':  test_fe['Index'].values,
    'demand': final_pred,
})
submission.to_csv('submission.csv', index=False)
print(f"\n✅ submission.csv saved — shape: {submission.shape}")
print(submission.head(10).to_string())
